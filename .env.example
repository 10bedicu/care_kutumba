# Care Kutumba Plugin Environment Variables
# Copy this file to .env and fill in the values

# ============================================
# Required Kutumba API Configuration
# ============================================

# API endpoint URL
KUTUMBA_API_URL=url_to_kutumba_api_here

# Client code provided by Kutumba
KUTUMBA_CLIENT_CODE=your_client_code_here

# ============================================
# Security Credentials (KEEP SECRET!)
# ============================================
# These values are sensitive and should never be committed to version control

# HMAC key for request authentication (used for HMAC-SHA256 signature)
KUTUMBA_HMAC_KEY=your_hmac_secret_key_here

# AES encryption key (32 characters for AES-256-CBC)
KUTUMBA_AES_KEY=your_32_character_aes_key_here

# AES Initialization Vector (16 characters for AES-256-CBC)
KUTUMBA_AES_IV=your_16_char_iv_here

# ============================================
# Optional Configuration
# ============================================

# API version (default: 1.0)
KUTUMBA_API_VERSION=1.0

# Request timeout in seconds (default: 30)
KUTUMBA_TIMEOUT=30
